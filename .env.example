# ============================================================
# Google Cloud Storage configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The .env file is listed in .gitignore and will NOT be committed.

# Name of the GCS bucket that holds the raw dataset files.
GCS_BUCKET_NAME=product-recommender-systems

# (Optional) GCP project ID.
# When omitted the project is inferred from Application Default Credentials.
# GCS_PROJECT_ID=my-gcp-project

# (Optional) Absolute path to a service-account JSON key file.
# When omitted the client falls back to Application Default Credentials
# (e.g. gcloud auth application-default login, Workload Identity, etc.).
# GCS_CREDENTIALS=/path/to/service-account-key.json

# (Optional) Local directory where raw data files are stored.
# Defaults to data/raw relative to the project root.
# DATA_RAW_DIR=data/raw
