# Streamlit Community Cloud secrets
# Copy this file to .streamlit/secrets.toml and fill in real values for local dev.
# On Streamlit Cloud, set these in App Settings → Secrets.

HF_TOKEN  = "hf_..."                                  # your HF read/write token
HF_REPO_ID = "biplobgon/product-recommendation-data"  # HF dataset repo with models
